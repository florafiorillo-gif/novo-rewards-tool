datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Geo {
  US
  India
  Colombia
}

enum EmploymentType {
  employee
  contractor
}

enum RecognitionPreference {
  public
  team_only
  private
}

enum BudgetPeriodStatus {
  draft
  approved
  active
  closed
}

enum PoolType {
  manager_tier1
  peer_tier1
  department_tier2
  committee_tier3
  reserve
}

enum NominationStatus {
  submitted
  under_review
  approved
  denied
  fulfilled
  cancelled
}

enum ApprovalActionType {
  approve
  deny
  propose_upgrade
  escalate
  request_info
  recuse
  group_into_team_award
  undo
}

enum DenialReason {
  failed_loophole
  value_mismatch
  already_recognized
  insufficient_detail
  other
}

enum RewardType {
  cash
  gift_card
  experience
  l_and_d
  custom
}

enum RewardStatus {
  selected
  issued
  delivered
  failed
  unclaimed
}

enum DeliveryMechanism {
  tremendous
  justworks_csv
  zoho_payroll
  manual
}

enum CommitteeDecisionType {
  approve
  deny
  defer
}

enum DigestStatus {
  draft
  published
}

// Captured on manager self-approval (spec §7.2). Structured so Phase 7 dashboards
// can aggregate manager-to-direct recognition rhythms without parsing free text.
enum ReflectionType {
  FIRST_RECOGNITION
  SPECIFIC_MOMENT
  BROADER_PATTERN
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────────────────

// Section 12.1 — synced from Zoho; id is the Zoho employee ID
model Employee {
  id                      String                @id
  name                    String
  email                   String                @unique
  geo                     Geo
  manager_id              String?
  manager                 Employee?             @relation("EmployeeManager", fields: [manager_id], references: [id])
  direct_reports          Employee[]            @relation("EmployeeManager")
  role_title              String
  active                  Boolean               @default(true)
  employment_type         EmploymentType        @default(employee)
  recognition_preference  RecognitionPreference @default(public)
  // Department is a string for v1 (Engineering / People / Operations / …).
  // A full Department table is deferred; the boolean flags below are sufficient
  // for Tier 2 routing in a ~200-person org.
  department              String?
  is_department_head      Boolean               @default(false)
  is_people_team_rep      Boolean               @default(false)
  is_committee_member     Boolean               @default(false)
  // Round-robin counter for Tier 2 People team assignments (spec §7.4).
  // Incremented at propose-upgrade time; rep with the lowest count wins ties.
  tier2_assignments_count Int                   @default(0)
  created_at              DateTime              @default(now())
  updated_at              DateTime              @updatedAt

  nominations_sent              Nomination[]        @relation("NominatorNominations")
  nominations_received          Nomination[]        @relation("NomineeNominations")
  nominations_pending           Nomination[]        @relation("CurrentApprover")
  approval_actions              ApprovalAction[]
  reactions                     Reaction[]
  comments                      Comment[]
  managed_pools                 BudgetPool[]        @relation("PoolOwner")
  digests_published             Digest[]
  budget_exceptions_approved    BudgetException[]
  team_awards_created           TeamAwardGroup[]
  committee_decisions_delivered CommitteeDecision[] @relation("CommitteeDecisionDeliveredBy")

  // Supports round-robin People team rep picker (ORDER BY
  // tier2_assignments_count ASC) and dept-head lookup by {department, geo}.
  @@index([is_people_team_rep, tier2_assignments_count])
  @@index([is_department_head, department, geo])
}

// Section 12.2 — static list, editable only by admin
model Value {
  id          String  @id @default(cuid())
  name        String  @unique
  description String  @db.Text
  active      Boolean @default(true)

  nominations Nomination[]
}

// Section 12.3
model BudgetPeriod {
  id                   String             @id @default(cuid())
  period_label         String
  start_date           DateTime
  end_date             DateTime
  total_allocation_usd Decimal            @db.Decimal(10, 2)
  status               BudgetPeriodStatus @default(draft)
  approved_by          String[] // array of Employee IDs
  approved_at          DateTime?
  // Spec §10 — v1 default split percentages, committee adjusts per quarter.
  // Shape defined in modules/budget/types.ts (AllocationConfig).
  allocation_config    Json?
  // Spec §10.4 + Phase 4 decision — set when committee closes the period.
  // Pools stay drawable for 14 days after closed_at for in-flight approvals
  // (Phase 5 reward-selection enforces the lapse check).
  closed_at            DateTime?

  pools BudgetPool[]

  @@index([status, start_date])
}

// Section 12.4 — remaining_amount_usd maintained by budget engine (allocated - spent - reserved)
// Phase 4 decision: no pre-reservation during approval/reward-selection.
// commitSpend is atomic (check-then-increment); reserved_amount_usd stays 0
// in v1 but the column remains for v2 if Finance wants hold semantics.
model BudgetPool {
  id                   String       @id @default(cuid())
  period_id            String
  period               BudgetPeriod @relation(fields: [period_id], references: [id])
  pool_type            PoolType
  geo                  Geo? // null for committee_tier3 and reserve
  owner_id             String? // manager or department head employee ID; null for peer/committee/reserve
  owner                Employee?    @relation("PoolOwner", fields: [owner_id], references: [id])
  // Department this pool covers — only set when pool_type=department_tier2.
  // Keyed with {geo, department} for dept-head pool lookups.
  department           String?
  allocated_amount_usd Decimal      @db.Decimal(10, 2)
  spent_amount_usd     Decimal      @default(0) @db.Decimal(10, 2)
  reserved_amount_usd  Decimal      @default(0) @db.Decimal(10, 2)
  remaining_amount_usd Decimal      @db.Decimal(10, 2)

  budget_exceptions BudgetException[]

  @@index([period_id, pool_type, geo])
  @@index([period_id, pool_type, department, geo])
  @@index([owner_id])
}

// Section 12.5 — core nomination object; tier defaults to 1, routing determined at submission
model Nomination {
  id                       String           @id @default(cuid())
  nominator_id             String
  nominator                Employee         @relation("NominatorNominations", fields: [nominator_id], references: [id])
  nominee_id               String
  nominee                  Employee         @relation("NomineeNominations", fields: [nominee_id], references: [id])
  value_id                 String
  value                    Value            @relation(fields: [value_id], references: [id])
  behavior_text            String           @db.Text
  outcome_text             String           @db.Text
  evidence_links           String[]
  submitted_at             DateTime         @default(now())
  current_tier             Int              @default(1)
  status                   NominationStatus @default(submitted)
  current_approver_id      String?
  current_approver         Employee?        @relation("CurrentApprover", fields: [current_approver_id], references: [id])
  team_award_group_id      String?
  team_award_group         TeamAwardGroup?  @relation(fields: [team_award_group_id], references: [id])
  // Signal only — links to the most recent prior nomination (same nominator → same nominee)
  // within 7 days. Phase 6 surfaces this as a "maybe add a corroborating comment" prompt.
  duplicate_of_id          String?
  duplicate_of             Nomination?      @relation("NominationDuplicate", fields: [duplicate_of_id], references: [id])
  duplicates               Nomination[]     @relation("NominationDuplicate")
  // Snapshot of the two required Tier 2 approvers at propose-upgrade time
  // (spec §7.4). Holding the snapshot here keeps the queue stable if either
  // role changes mid-review. Both null unless the nomination is at Tier 2.
  tier2_dept_head_id       String?
  tier2_people_team_rep_id String?
  // Tier 3 urgent flag (spec §7.5). Triggers a Slack ping to committee members
  // and a badge in the committee queue; does not change the approval path.
  urgent                   Boolean          @default(false)
  // SLA tracking (spec §7.6). last_nudge_at is set when the 72h nudge fires;
  // last_escalation_at when the 7d escalation fires; used to prevent re-firing.
  last_nudge_at            DateTime?
  last_escalation_at       DateTime?
  // Terminal-state timestamps (separate from the ApprovalAction audit trail so
  // queries can filter by decision time without a join).
  approved_at              DateTime?
  denied_at                DateTime?
  created_at               DateTime         @default(now())
  updated_at               DateTime         @updatedAt

  reward              Reward?
  approval_actions    ApprovalAction[]
  reactions           Reaction[]
  comments            Comment[]
  budget_exceptions   BudgetException[]
  committee_decisions CommitteeDecision[]

  // Phase 2 duplicate-signal + Tier 1 approver queue.
  @@index([nominator_id, nominee_id, submitted_at])
  @@index([current_approver_id, status])
  // Phase 3 Tier 2 queue filters (per-approver snapshot) and committee
  // queue + SLA sweep ordering by tier/status/submitted_at.
  @@index([tier2_dept_head_id, status, current_tier])
  @@index([tier2_people_team_rep_id, status, current_tier])
  @@index([current_tier, status, submitted_at])
}

// Section 12.6 — full audit trail; every decision creates a record
model ApprovalAction {
  id                String             @id @default(cuid())
  nomination_id     String
  nomination        Nomination         @relation(fields: [nomination_id], references: [id])
  actor_id          String
  actor             Employee           @relation(fields: [actor_id], references: [id])
  action            ApprovalActionType
  from_tier         Int?
  to_tier           Int?
  reason_structured DenialReason?
  reason_text       String?            @db.Text
  // Populated only when a manager self-approves a direct report (spec §7.2).
  // Structured for Phase 7 aggregation rather than parsing reason_text.
  reflection_type   ReflectionType?
  created_at        DateTime           @default(now())

  @@index([nomination_id, created_at])
  // Used by isTier2FullyApproved + undoApproval to look up an actor's
  // most recent approve without scanning the whole trail.
  @@index([actor_id, action])
}

// Section 12.8 — reusable scope note copy per tier, editable by approver
model ScopeNoteTemplate {
  id            String  @id @default(cuid())
  tier          Int
  template_text String  @db.Text
  active        Boolean @default(true)

  rewards Reward[]
}

// Section 12.7 — one reward per nomination; FK lives here, not on Nomination
model Reward {
  id                     String             @id @default(cuid())
  nomination_id          String             @unique
  nomination             Nomination         @relation(fields: [nomination_id], references: [id])
  reward_type            RewardType
  vendor                 String?
  amount_usd             Decimal            @db.Decimal(10, 2)
  amount_local           Decimal?           @db.Decimal(10, 2)
  currency_local         String?
  status                 RewardStatus       @default(selected)
  delivery_mechanism     DeliveryMechanism
  scope_note_template_id String?
  scope_note_template    ScopeNoteTemplate? @relation(fields: [scope_note_template_id], references: [id])
  scope_note_text        String?            @db.Text
  issued_at              DateTime?
  delivered_at           DateTime?
}

// Section 12.10
model TeamAwardGroup {
  id          String   @id @default(cuid())
  created_at  DateTime @default(now())
  created_by  String
  creator     Employee @relation(fields: [created_by], references: [id])
  description String   @db.Text

  nominations         Nomination[]
  committee_decisions CommitteeDecision[]
}

// Section 12.9 — exactly one of nomination_id or team_award_group_id must be set (enforced in app)
model CommitteeDecision {
  id                   String                @id @default(cuid())
  nomination_id        String?
  nomination           Nomination?           @relation(fields: [nomination_id], references: [id])
  team_award_group_id  String?
  team_award_group     TeamAwardGroup?       @relation(fields: [team_award_group_id], references: [id])
  committee_members    String[] // array of Employee IDs
  decision             CommitteeDecisionType
  approved_amount_usd  Decimal?              @db.Decimal(10, 2)
  reward_form          String?
  delivery_plan        String?               @db.Text
  decision_log_text    String?               @db.Text
  conflicted_members   String[] // array of Employee IDs who recused
  substitute_member_id String?
  delivered_by_id      String?
  delivered_by         Employee?             @relation("CommitteeDecisionDeliveredBy", fields: [delivered_by_id], references: [id])
  delivered_at         DateTime?
  decided_at           DateTime              @default(now())
}

// Section 12.11 — emoji reactions on #made-it-happen posts
model Reaction {
  id            String     @id @default(cuid())
  nomination_id String
  nomination    Nomination @relation(fields: [nomination_id], references: [id])
  user_id       String
  user          Employee   @relation(fields: [user_id], references: [id])
  reaction_type String
  created_at    DateTime   @default(now())

  @@unique([nomination_id, user_id, reaction_type])
}

// Section 12.12 — threaded corroborating comments
model Comment {
  id            String     @id @default(cuid())
  nomination_id String
  nomination    Nomination @relation(fields: [nomination_id], references: [id])
  user_id       String
  user          Employee   @relation(fields: [user_id], references: [id])
  text          String     @db.Text
  created_at    DateTime   @default(now())
}

// Section 12.13 — auto-drafted monthly; People team edits and publishes
model Digest {
  id                      String       @id @default(cuid())
  period                  String // YYYY-MM
  status                  DigestStatus @default(draft)
  content                 String       @db.Text
  featured_nomination_ids String[]
  published_at            DateTime?
  published_by_id         String?
  published_by            Employee?    @relation(fields: [published_by_id], references: [id])
}

// Section 12.14 — logged when an approval draws from the reserve pool
model BudgetException {
  id            String     @id @default(cuid())
  nomination_id String
  nomination    Nomination @relation(fields: [nomination_id], references: [id])
  pool_id       String
  pool          BudgetPool @relation(fields: [pool_id], references: [id])
  amount_usd    Decimal    @db.Decimal(10, 2)
  approver_id   String
  approver      Employee   @relation(fields: [approver_id], references: [id])
  reason_text   String?    @db.Text
  created_at    DateTime   @default(now())
}
