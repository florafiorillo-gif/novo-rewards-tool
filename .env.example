# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=http://localhost:3000

# Restrict sign-in to this Google Workspace domain
AUTH_ALLOWED_DOMAIN=novo.co

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-

# ─── Reward Fulfillment (Tremendous) ──────────────────────────────────────────
TREMENDOUS_API_KEY=
TREMENDOUS_SANDBOX=true

# ─── Zoho HR ──────────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Shared bearer secret for the SLA sweep endpoint at /api/cron/sla.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ─── Dev flags ────────────────────────────────────────────────────────────────
# Set to "true" to bypass DB and use mock employee data
USE_MOCK_DATA=true
